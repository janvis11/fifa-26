# Anthropic API Key for GenAI features.
# If left blank, the application will degrade gracefully and run in offline mock mode.
ANTHROPIC_API_KEY=

# The Claude model to use for live mode (default: claude-sonnet-4-6)
# Note: Usually this maps to claude-3-5-sonnet-20241022 or similar depending on Anthropic's updates
ANTHROPIC_MODEL=claude-sonnet-4-6

# Comma-separated list of allowed CORS origins (no wildcards in production paths)
# Example: http://localhost:8000,http://127.0.0.1:8000
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate limit per minute per client IP for chat/translate endpoints
RATE_LIMIT_PER_MINUTE=60
